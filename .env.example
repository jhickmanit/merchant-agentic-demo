# Ory Network (project provisioned 2026-05-13)
ORY_PROJECT_ID=f5798507-b1c0-4168-9fd8-7eeb7a40d75c
# For server-side/admin calls and e2e tests, the direct project URL works.
# For browser sign-in on localhost, you MUST run `ory tunnel` (see README) and
# change this to http://localhost:4000 so the Kratos session cookie lands on
# localhost. Without that swap, browser sign-in redirect-loops and Ory's edge
# eventually returns 429 / ERR_CONNECTION_REFUSED.
ORY_SDK_URL=https://eager-dhawan-mio9f9ilcu.projects.oryapis.com
ORY_ADMIN_API_KEY=

# Skyfire (set in Phase 8 when seller account is provisioned)
SKYFIRE_API_KEY=

# Local SQLite
DATABASE_URL=./local.db

# Provider selection (mock for demo, skyfire for real KYA tokens)
AUTH_PROVIDER=ory
KYAPAY_PROVIDER=mock

# Phase 5 — demo agent scripts use a shared Hydra OAuth2 client.
# Create one via the Ory dashboard (or `ory create oauth2-client`) with
# grant_types=["client_credentials"] and copy the client_id + client_secret here.
DEMO_AGENT_CLIENT_ID=
DEMO_AGENT_CLIENT_SECRET=

# Phase 10 — skyfire-bridge OAuth2 client. Every auto-provisioned Skyfire
# agent bootstraps its delegated token through this single shared client.
# Provisioned by `./scripts/ory-setup/hydra-config.sh` (idempotent); copy the
# printed client_id/client_secret here. The secret is shown only once on
# create — re-running the script will detect the existing client but cannot
# recover its secret.
SKYFIRE_BRIDGE_CLIENT_ID=
SKYFIRE_BRIDGE_CLIENT_SECRET=

# Phase 6 — mock Skyfire keypair (ES256). Generate via:
#   pnpm gen:mock-skyfire-keys
# then paste both lines into .env.local. DO NOT commit the private key.
MOCK_SKYFIRE_PRIVATE_KEY_JWK=
MOCK_SKYFIRE_PUBLIC_KEY_JWK=

SKYFIRE_BUYER_API_KEY=